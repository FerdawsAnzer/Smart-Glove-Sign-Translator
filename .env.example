# Supabase (required unless using Demo Mode below)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Demo Mode,set to "true" to explore the app WITHOUT a live Supabase
# connection. Skips real login and uses a mock user, so anyone cloning
# the repo can try the UI without setting up Supabase credentials.

VITE_DEMO_MODE=false